{
  "mqtt": {
    "host": "scada.tmnsoft.vn",
    "port": 1883,
    "username": "gateway_demo_site",
    "password": "MAT_KHAU_MQTT_CUA_BAN",
    "use_tls": false
  },
  "site_key": "demo_site",
  "devices": [
    {
      "_comment": "Modbus TCP - PLC/biến tần có cổng Ethernet",
      "device_key": "plc_modbus_tcp",
      "protocol": "modbus_tcp",
      "connection": {
        "ip": "192.168.1.10",
        "port": 502,
        "slave_id": 1
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "temp1",
          "address": "0",
          "data_type": "int16",
          "scale": 10
        },
        {
          "tag_key": "pressure",
          "address": "1",
          "data_type": "float32",
          "scale": 1
        }
      ]
    },
    {
      "_comment": "Modbus RTU RS485 - biến tần, đồng hồ điện (USB-RS485 converter)",
      "device_key": "bien_tan_rs485",
      "protocol": "modbus_rtu",
      "connection": {
        "port": "/dev/ttyUSB0",
        "baudrate": 9600,
        "parity": "N",
        "stopbits": 1,
        "slave_id": 1
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "tan_so",
          "address": "0",
          "data_type": "int16",
          "scale": 100
        },
        {
          "tag_key": "dong_dien",
          "address": "1",
          "data_type": "float32",
          "scale": 1
        }
      ]
    },
    {
      "_comment": "LS XGB qua USB-RS232 (Windows: COMx, Linux: /dev/ttyUSB0). Parity PHẢI là E (Even)!",
      "device_key": "plc_ls_xgb",
      "protocol": "ls_xgb",
      "connection": {
        "port": "COM8",
        "baudrate": 9600,
        "parity": "E",
        "stopbits": 1,
        "slave_id": 1,
        "timeout": 5
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "mw0",
          "address": "0",
          "data_type": "int16",
          "scale": 1,
          "_comment": "Đọc D register thường"
        },
        {
          "tag_key": "m1_coil",
          "address": "1",
          "data_type": "coil",
          "_comment": "Đọc/ghi coil M1 — dùng cho điều khiển ON/OFF output"
        },
        {
          "tag_key": "d0_bit3",
          "address": "0",
          "data_type": "bit:3",
          "_comment": "Đọc/ghi bit thứ 3 trong D0"
        }
      ]
    },
    {
      "_comment": "Delta DVP RS485 - parity Even mặc định",
      "device_key": "plc_delta",
      "protocol": "delta_dvp",
      "connection": {
        "port": "/dev/ttyUSB1",
        "baudrate": 9600,
        "parity": "E",
        "stopbits": 1,
        "slave_id": 1
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "d0",
          "address": "0",
          "data_type": "int16",
          "scale": 1
        }
      ]
    },
    {
      "_comment": "Siemens S7-1200/1500. Rack=0, Slot=1 cho S7-1200/1500; Slot=2 cho S7-300",
      "device_key": "plc_siemens",
      "protocol": "s7",
      "connection": {
        "ip": "192.168.1.20",
        "rack": 0,
        "slot": 1
      },
      "poll_interval": 10,
      "tags": [
        {
          "tag_key": "nhiet_do",
          "address": "DB1.DBD0",
          "data_type": "float32"
        },
        {
          "tag_key": "dem_san_pham",
          "address": "DB1.DBW4",
          "data_type": "uint16"
        },
        {
          "tag_key": "den_loi",
          "address": "DB1.DBX8.0"
        }
      ]
    },
    {
      "_comment": "Mitsubishi MC Protocol - FX5U/Q series qua Ethernet. Port mặc định 5010.",
      "device_key": "plc_mitsubishi",
      "protocol": "mitsubishi_mc",
      "connection": {
        "ip": "192.168.1.30",
        "port": 5010
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "d100",
          "address": "D100",
          "data_type": "int16",
          "scale": 1
        },
        {
          "tag_key": "d200_float",
          "address": "D200F",
          "data_type": "float32"
        },
        {
          "tag_key": "m0",
          "address": "M0"
        }
      ]
    },
    {
      "_comment": "Omron FINS/UDP - CP1L-E, CJ2, NX series. dest_node = octet cuối IP của PLC.",
      "device_key": "plc_omron",
      "protocol": "omron_fins",
      "connection": {
        "ip": "192.168.1.40",
        "port": 9600,
        "dest_node": 40,
        "src_node": 100
      },
      "poll_interval": 5,
      "tags": [
        {
          "tag_key": "d0",
          "address": "D0",
          "data_type": "int16",
          "scale": 1
        },
        {
          "tag_key": "d100_float",
          "address": "D100F",
          "data_type": "float32"
        }
      ]
    },
    {
      "_comment": "OPC UA - đa hãng: Siemens TIA Portal, Beckhoff, KEPServerEX, WinCC...",
      "device_key": "plc_opcua",
      "protocol": "opcua",
      "connection": {
        "endpoint": "opc.tcp://192.168.1.50:4840"
      },
      "poll_interval": 10,
      "tags": [
        {
          "tag_key": "muc_nuoc",
          "address": "ns=2;s=Channel1.Device1.MucNuoc",
          "scale": 1
        }
      ]
    }
  ]
}